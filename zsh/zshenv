# ~/.zshenv — the first file zsh reads for every shell (login, interactive, script).
# Keep this minimal: only what MUST exist before .zprofile/.zshrc run.

# XDG base directories.
export XDG_CONFIG_HOME="${XDG_CONFIG_HOME:-$HOME/.config}"
export XDG_CACHE_HOME="${XDG_CACHE_HOME:-$HOME/.cache}"
export XDG_DATA_HOME="${XDG_DATA_HOME:-$HOME/.local/share}"
export XDG_STATE_HOME="${XDG_STATE_HOME:-$HOME/.local/state}"

# Relocate zsh's own dotfiles into $XDG_CONFIG_HOME/zsh so $HOME stays clean.
# Everything below this line lives in $ZDOTDIR (.zprofile, .zshrc, ...).
export ZDOTDIR="$XDG_CONFIG_HOME/zsh"
