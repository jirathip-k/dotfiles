[user]
	name = jirathip-k
	email = 115384744+jirathip-k@users.noreply.github.com

[init]
	defaultBranch = main

[core]
	editor = nvim
	pager = delta
	excludesfile = ~/.config/git/ignore

[fetch]
	prune = true
	prunetags = true

[pull]
	rebase = true

[push]
	autoSetupRemote = true
	followTags = true

[rebase]
	autosquash = true
	autostash = true

[rerere]
	enabled = true

[column]
	ui = auto

[branch]
	sort = -committerdate

[tag]
	sort = version:refname

[diff]
	colorMoved = default
	algorithm = histogram

[merge]
	conflictstyle = zdiff3

[url "https://github.com/"]
	insteadOf = gh:

[interactive]
	diffFilter = delta --color-only

[delta]
	navigate = true
	side-by-side = true

[filter "lfs"]
	clean = git-lfs clean -- %f
	smudge = git-lfs smudge -- %f
	process = git-lfs filter-process
	required = true

# Use the gh CLI for GitHub auth. PATH-resolved so it works on macOS + Linux.
[credential "https://github.com"]
	helper =
	helper = !gh auth git-credential
[credential "https://gist.github.com"]
	helper =
	helper = !gh auth git-credential
